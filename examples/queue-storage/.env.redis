# Activate the Redis-backed Storage provider.
#
# Usage:
#   docker compose --env-file .env.redis --profile redis up --build
#
# The `--profile redis` flag pulls in the Redis sidecar; these env vars
# tell the server to use it instead of the in-memory default.
A2A_QUEUE_PROVIDER=redis
A2A_QUEUE_URL=redis://redis:6379
A2A_QUEUE_NAMESPACE=a2a
A2A_QUEUE_WORKERS=4
EXAMPLE_DELAY_MS=2000
EXAMPLE_TASKS=5
