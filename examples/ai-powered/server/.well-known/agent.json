{
  "name": "Rust A2A Toolbox Server",
  "description": "A2A server with custom function tools, built with the Rust ADK",
  "version": "0.1.0",
  "protocolVersion": "0.2.6",
  "url": "http://localhost:8082",
  "preferredTransport": "JSONRPC",
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "stateTransitionHistory": false
  },
  "provider": {
    "organization": "Inference Gateway",
    "url": "https://github.com/inference-gateway/rust-adk"
  },
  "skills": [
    {
      "id": "get_current_weather",
      "name": "get_current_weather",
      "description": "Look up the current weather for a location",
      "tags": ["weather", "tool"]
    },
    {
      "id": "calculate_math",
      "name": "calculate_math",
      "description": "Evaluate a basic math expression",
      "tags": ["math", "tool"]
    },
    {
      "id": "search_web",
      "name": "search_web",
      "description": "Mock web search returning sample results",
      "tags": ["search", "tool"]
    }
  ],
  "defaultInputModes": ["text/plain"],
  "defaultOutputModes": ["text/plain"]
}
